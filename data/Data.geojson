{ "type": "Feature", "properties": { "ID": "37", "attr_Історична довідка": "Будинок зведений у 1910 році як кінотеатр «Модерн». Із 1975 року в приміщенні працює дитяча музична школа №1 імені Миколи Мозгового (видатний український композитор). Будівля є пам’яткою архітектури місцевого значення. Адреса: вул. Проскурівська, 18.", "attr_Photo": "https://uk.wikipedia.org/wiki/%D0%91%D1%83%D0%B4%D0%B8%D0%BD%D0%BE%D0%BA_%D0%BD%D0%B0_%D0%B2%D1%83%D0%BB%D0%B8%D1%86%D1%96_%D0%9F%D1%80%D0%BE%D1%81%D0%BA%D1%83%D1%80%D1%96%D0%B2%D1%81%D1%8C%D0%BA%D1%96%D0%B9,_18_(%D0%A5%D0%BC%D0%B5%D0%BB%D1%8C%D0%BD%D0%B8%D1%86%D1%8C%D0%BA%D0%B8%D0%B9)", "attr_Title": "Кінотеатр «Модерн» (власник І.Я. Штейншлегера) (мур.)", "attr_Статус": "Щойно виявлений об'єкт", "attr_Охоронний номер": null, "attr_Вид": "Архітектура", "attr_Країна": "Україна", "attr_Область": "Хмельницька", "attr_Місто": "Хмельницький", "attr_Тип ВДМ": "вул.", "attr_Вулиця": "Проскурівська", "attr_Номер будинку": "18", "attr_для геокодування": "Україна Хмельницька Хмельницький вул.Проскурівська, 18", "attr_Latitude": "49.42469579999999", "attr_Longitude": 26.983677, "attr_Дата рішення": "15.09.2010", "attr_Номер рішення": 242, "attr_Орган прийняття (оригінальна назва)": "Хмельницька міська Рада народних депутатів", "attr_Орган прийняття (тип)": "Міська рада", "attr_Власність": "Комунальна", "attr_Датування": "1910 р.", "attr_Дата початку": null, "attr_Дата завершення": null, "attr_Первісне призначення": "Кінотеатр", "attr_Сучасне призначення": "Музична школа", "attr_Матеріал": "Цегла", "attr_Автор": null, "attr_Основні розміри": null }, "geometry": { "type": "Polygon", "coordinates": [ [ [ 26.9833701, 49.4248777 ], [ 26.9834747, 49.4249625 ], [ 26.9838899, 49.4247353 ], [ 26.9837266, 49.4246052 ], [ 26.9835016, 49.4247242 ], [ 26.9835651, 49.4247739 ], [ 26.9834052, 49.4248594 ], [ 26.9833701, 49.4248777 ] ] ] } },
{ "type": "Feature", "properties": { "ID": "8", "attr_Історична довідка": "Будинок зведений на початку ХХ століття у стилі модерн. У 1908 році тут працювали ресторан «Слон» і готельні номери. У радянський період будівля неодноразово змінювала функції. Відомо, що у 1938 році тут зупинялася знімальна група видатного українського кінорежисера Олександра Довженка. Нині в будівлі розташовані ресторан, коворкінг та Бюро технічної інвентаризації.  Адреса: вул. Проскурівська, 15.", "attr_Source": "https://www.linza.in.ua/unikalna-budivlya-na-proskurivskij-15-istoriya-restoranu-slon-ta-jogo-arhitekturna-spadshhyna/", "attr_Photo": "https://uk.wikipedia.org/wiki/%D0%A4%D0%B0%D0%B9%D0%BB:%D0%A1%D0%BB%D0%BE%D0%BD_(%D1%80%D0%B5%D1%81%D1%82%D0%BE%D1%80%D0%B0%D0%BD,_%D0%A5%D0%BC%D0%B5%D0%BB%D1%8C%D0%BD%D0%B8%D1%86%D1%8C%D0%BA%D0%B8%D0%B9).jpg", "attr_Title": "Ресторан \"Слон\" (мур.)", "attr_Статус": "Щойно виявлений об'єкт", "attr_Охоронний номер": null, "attr_Вид": "Архітектура", "attr_Країна": "Україна", "attr_Область": "Хмельницька", "attr_Місто": "Хмельницький", "attr_Тип ВДМ": "вул.", "attr_Вулиця": "Проскурівська", "attr_Номер будинку": "15", "attr_для геокодування": "Україна Хмельницька Хмельницький вул.Проскурівська, 15", "attr_Latitude": "49.4251204", "attr_Longitude": 26.983759, "attr_Дата рішення": "15.09.2010", "attr_Номер рішення": 242, "attr_Орган прийняття (оригінальна назва)": "Хмельницька міська Рада народних депутатів", "attr_Орган прийняття (тип)": "Міська рада", "attr_Власність": "Приватна, комунальна", "attr_Датування": "кінець ХІХ ст.", "attr_Дата початку": null, "attr_Дата завершення": null, "attr_Первісне призначення": "Ресторан", "attr_Сучасне призначення": "Ресторан, офіси", "attr_Матеріал": "Цегла", "attr_Автор": null, "attr_Основні розміри": null }, "geometry": { "type": "Polygon", "coordinates": [ [ [ 26.9839532, 49.4249275 ], [ 26.9835108, 49.4251513 ], [ 26.9835077, 49.4251959 ], [ 26.983659, 49.425333 ], [ 26.9837941, 49.4252709 ], [ 26.9837296, 49