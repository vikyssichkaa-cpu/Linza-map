{ "type": "Feature", "properties": { "ID": "9", "attr_Історична довідка": "Будинок кінця ХІХ століття зведений як прибутковий дім купця Ізраїля Толпіна. Архітектура споруди поєднує риси неоренесансу та модерну. Традиційно перший поверх займали крамниці, а верхні поверхи використовувалися як житлові приміщення. Адреса: вул. Проскурівська, 17.", "attr_Photo": "https://uk.wikipedia.org/wiki/%D0%91%D1%83%D0%B4%D0%B8%D0%BD%D0%BE%D0%BA_%D0%BC%D0%B0%D0%B3%D0%B0%D0%B7%D0%B8%D0%BD%D1%83_%D0%BC%D0%B0%D0%BD%D1%83%D0%B0%D0%BA%D1%82%D1%83%D1%80%D0%B8_(%D0%A5%D0%BC%D0%B5%D0%BB%D1%8C%D0%BD%D0%B8%D1%86%D1%8C%D0%BA%D0%B8%D0%B9)", "attr_Title": "Магазин мануфактури (мур.)", "attr_Статус": "Щойно виявлений об'єкт", "attr_Охоронний номер": null, "attr_Вид": "Архітектура", "attr_Країна": "Україна", "attr_Область": "Хмельницька", "attr_Місто": "Хмельницький", "attr_Тип ВДМ": "вул.", "attr_Вулиця": "Проскурівська", "attr_Номер будинку": "17", "attr_для геокодування": "Україна Хмельницька Хмельницький вул.Проскурівська, 17", "attr_Latitude": "49.4248888", "attr_Longitude": 26.9841088, "attr_Дата рішення": "15.09.2010", "attr_Номер рішення": 242, "attr_Орган прийняття (оригінальна назва)": "Хмельницька міська Рада народних депутатів", "attr_Орган прийняття (тип)": "Міська рада", "attr_Власність": "Приватна, комунальна", "attr_Датування": "ІІ пол. ХІХ ст.", "attr_Дата початку": null, "attr_Дата завершення": null, "attr_Первісне призначення": "Магазин", "attr_Сучасне призначення": "Магазин, офіси", "attr_Матеріал": "Цегла", "attr_Автор": null, "attr_Основні розміри": null }, "geometry": { "type": "Polygon", "coordinates": [ [ [ 26.9839695, 49.4249111 ], [ 26.9840955, 49.4250154 ], [ 26.9842183, 49.4249527 ], [ 26.9842605, 49.4249877 ], [ 26.9843123, 49.4249613 ], [ 26.9842662, 49.4249231 ], [ 26.9843388, 49.4248861 ], [ 26.9842166, 49.4247848 ], [ 26.9839695, 49.4249111 ] ] ] } },
{ "type": "Feature", "properties": { "ID": "65", "attr_Історична довідка": "Церква святого Миколая Чудотворця, зведена у 1904 році як полкова. За радянської влади приміщення використовувалося як спортивний зал. У 1991 році храм повернули громаді, після чого він був відроджений як собор святого Андрія Первозванного. Адреса: вул. Козацька, 69.", "attr_Photo": "https://uk.wikipedia.org/wiki/%D0%A4%D0%B0%D0%B9%D0%BB:%D0%A6%D0%B5%D1%80%D0%BA%D0%B2%D0%B0_%D0%A5%D0%BC%D0%B5%D0%BB%D1%8C%D0%BD%D0%B8%D1%86%D1%8C%D0%BA%D0%B8%D0%B9_%D0%B2%D1%83%D0%BB._%D0%9A%D0%BE%D0%B7%D0%B0%D1%86%D1%8C%D0%BA%D0%B0,_69.JPG", "attr_Title": "Будинок", "attr_Статус": "Щойно виявлений об'єкт", "attr_Охоронний номер": null, "attr_Вид": "Архітектура", "attr_Країна": "Україна", "attr_Область": "Хмельницька", "attr_Місто": "Хмельницький", "attr_Тип ВДМ": "вул.", "attr_Вулиця": "Козацька", "attr_Номер будинку": "69", "attr_для геокодування": "Україна Хмельницька Хмельницький вул.Козацька, 69", "attr_Latitude": "49.4066169", "attr_Longitude": 26.9925992, "attr_Дата рішення": "15.09.2010", "attr_Номер рішення": 242, "attr_Орган прийняття (оригінальна назва)": "Управління культури, туризму і курортів Хмельницької ОДА", "attr_Орган прийняття (тип)": "ОДА", "attr_Власність": "Релігійна громада", "attr_Датування": "1904", "attr_Дата початку": null, "attr_Дата завершення": null, "attr_Первісне призначення": "Полкова церква", "attr_Сучасне призначення": "Кафедральний собор Андрія Первозваного УПЦ", "attr_Матеріал": "Цегла", "attr_Автор": null, "attr_Основні розміри": null }, "geometry": { "type": "Polygon", "coordinates": [ [ [ 26.9928658, 49.4065694 ], [ 26.9925552, 49.4065959 ], [ 26.9925533, 49.4065866 ], [ 26.9924916, 49.4065919 ], [ 26.9924934, 49.4066007 ], [ 26.9923248, 49.406615 ], [ 26.9923533, 49.406757 ], [ 26.9925312, 49.4067419 ], [ 26.9925286, 49.4067288 ], [ 26.9928916, 49.4066979 ], [ 26.9928658, 49.4065694 ] ] ] } },
{ "type": "Feature", "properties": { "ID": "44", "attr_Історична довідка": "Хмельницька пожежна каланча — оглядова вежа при будівлі пожежної команди. Проєкт розробив архітектор Гнат Чекірда у 1946 році, будівництво тривало у 1951–1954 роках. Згодом у будівлі розмістився кінотеатр «Планета», а у 2004 році на вежі встановили музичний годинник. Адреса: вул. Подільська, 39.", "attr_Source": "https://www.linza.in.ua/hmelnyczka-kalancha-shho-cze-ta-chomu-plutayut-z-ratusheyu/", "attr_Photo": "https://www.linza.in.ua/hmelnyczka-kalancha-shho-cze-ta-chomu-plutayut-z-ratusheyu/", "attr_Title": "Пожежне депо (мур.)", "attr_Статус": "Щойно виявлений об'єкт", "attr_Охоронний номер": null, "attr_Вид": "Архітектура", "attr_Країна": "Україна", "attr_Область": "Хмельницька", "attr_Місто": "Хмельницький", "attr_Тип ВДМ": "вул.", "attr_Вулиця": "Подільська", "attr_Номер будинку": "39", "attr_для геокодування": "Україна Хмельницька Хмельницький вул.Подільська, 39", "attr_Latitude": "49.427007", "attr_Longitude": 26.9804501, "attr_Дата рішення": "15.09.2010", "attr_Номер рішення": 242, "attr_Орган прийняття (оригінальна назва)": "Хмельницька міська Рада народних депутатів", "attr_Орган прийняття (тип)": "Міська рада", "attr_Власність": "Комунальна", "attr_Датування": "1956 р.", "attr_Дата початку": null, "attr_Дата завершення": null, "attr_Первісне призначення": "Пожежне депо", "attr_Сучасне призначення": "Кінотеатр \"Планета\"", "attr_Матеріал": "Цегла", "attr_Автор": null, "attr_Основні розміри": null }, "geometry": { "type": "Polygon", "coordinates": [ [ [ 26.9807767, 49.4269412 ], [ 26.9801617, 49.4270126 ], [ 26.980169, 49.4270446 ], [ 26.9801935, 49.4271472 ], [ 26.9808136, 49.4270765 ], [ 26.9807821, 49.426961 ], [ 26.9807767, 49.4269412 ] ] ] } },
{ "type": "Feature", "properties": { "ID": "32", "attr_Історична довідка": "Мікрорайон Дубове почав формуватися наприкінці ХІХ століття як військове містечко. Ключовою спорудою району є водонапірна вежа, зведена у 1910 році за проєктом архітектора Віктора Нільсена. Вежа забезпечувала район водою до кінця 1990-х років. Адреса: вул. Кушнірука.", "attr_Source": "https://www.linza.in.ua/mikrorajon-dubove-yak-peredmistya-stalo-mikrorajonom-hmelnyczkogo/", "attr_Photo": "https://www.linza.in.ua/mikrorajon-dubove-yak-peredmistya-stalo-mikrorajonom-hmelnyczkogo/", "attr_Title": "Будинок", "attr_Статус": "Щойно виявлений об'єкт", "attr_Охоронний номер": null, "attr_Вид": "Архітектура", "attr_Країна": "Україна", "attr_Область": "Хмельницька", "attr_Місто": "Хмельницький", "attr_Тип ВДМ": "вул.", "attr_Вулиця": "Кушнірука", "attr_Номер будинку": null, "attr_для геокодування": "Україна Хмельницька Хмельницький вул.Кушнірука, ", "attr_Latitude": "49.40714504581564", "attr_Longitude": 26.989693695373148, "attr_Дата рішення": "15.09.2010", "attr_Номер рішення": 242, "attr_Орган прийняття (оригінальна назва)": "\nУправління культури, туризму і курортів Хмельницької ОДА", "attr_Орган прийняття (тип)": "ОДА", "attr_Власність": "Комунальна", "attr_Датування": "кін. ХІХ - поч. ХХ ст.", "attr_Дата початку": null, "attr_Дата завершення": null, "attr_Первісне призначення": "Водонапірна вежа", "attr_Сучасне призначення": "Водонапірна вежа (не діюча)", "attr_Матеріал": "Цегла", "attr_Автор": null, "attr_Основні розміри": null }, "geometry": { "type": "Polygon", "coordinates": [ [ [ 26.9895253, 49.4069467 ], [ 26.9896114, 49.4073142 ], [ 26.9897734, 49.4072981 ], [ 26.9896873, 49.4069306 ], [ 26.9895253, 49.4069467 ] ] ] } },
{ "type": "Feature", "properties": { "ID": "12", "attr_Історична довідка": "Будинок на розі вулиць Проскурівської та Володимирської збудував у 1903 році підприємець Давид Ніренберг для потреб банку. Також тут діяли готель «Венеція» та ресторан «Сан-Ремо». У 1919 році будівлю відвідував видатний український військовий діяч Петро Болбочан. Адреса: вул. Проскурівська, 47.", "attr_Source": "https://www.linza.in.ua/hotel-proskurova-v-yakomu-zupynyalysya-uryadovci-unr-de-znakhodyvsya/", "attr_Photo": "https://uk.wikipedia.org/wiki/%D0%91%D1%83%D0%B4%D0%B8%D0%BD%D0%BE%D0%BA_%D0%9F%D1%96%D0%B2%D0%B4%D0%B5%D0%BD%D0%BD%D0%BE-%D0%A0%D0%BE%D1%81%D1%96%D0%B9%D1%81%D1%8C%D0%BA%D0%BE%D0%B3%D0%BE_%D0%B1%D0%B0%D0%BD%D0%BA%D1%83_(%D0%A5%D0%BC%D0%B5%D0%BB%D1%8C%D0%BD%D0%B8%D1%86%D1%8C%D0%BA%D0%B8%D0%B9)", "attr_Title": "Об’єднаний банк (домовласник Ніренберг) (мур.)", "attr_Статус": "Щойно виявлений об'єкт", "attr_Охоронний номер": null, "attr_Вид": "Архітектура", "attr_Країна": "Україна", "attr_Область": "Хмельницька", "attr_Місто": "Хмельницький", "attr_Тип ВДМ": "вул.", "attr_Вулиця": "Проскурівська", "attr_Номер будинку": "47", "attr_для геокодування": "Україна Хмельницька Хмельницький вул.Проскурівська, 47", "attr_Latitude": "49.423046", "attr_Longitude": 26.9876227, "attr_Дата рішення": "15.09.2010", "attr_Номер рішення": 242, "attr_Орган прийняття (оригінальна назва)": "Хмельницька міська Рада народних депутатів", "attr_Орган прийняття (тип)": "Міська рада", "attr_Власність": "Комунальна", "attr_Датування": "1903 р.", "attr_Дата початку": null, "attr_Дата завершення": null, "attr_Первісне призначення": "Банк", "attr_Сучасне призначення": "\nХмельницький обласний художній музей", "attr_Матеріал": "Цегла", "attr_Автор": null, "attr_Основні розміри": null }, "geometry": { "type": "Polygon", "coordinates": [ [ [ 26.9880399, 49.4229867 ], [ 26.987937, 49.4228817 ], [ 26.9875019, 49.4230622 ], [ 26.9877257, 49.4232904 ], [ 26.9879029, 49.4232169 ], [ 26.9877821, 49.4230937 ], [ 26.98