{ "type": "Feature", "properties": { "ID": "1", "attr_Історична довідка": "Будівля на розі вулиць Гагаріна та Кам’янецької зведена у 1960 році для музично-драматичного театру імені Григорія Петровського (радянський державний діяч) із залом на 750 місць. У 1982 році театр переїхав до нового приміщення, а споруду передали обласній філармонії, яка працює тут дотепер. У 1995 році будівлю внесли до переліку пам’яток архітектури місцевого значення. Адреса: вул. Героїв Маріуполя, 7.", "attr_Photo": "https://mista.ua/%D0%9F%D0%B0%D0%BC%D1%8F%D1%82%D0%BA%D0%B8/%D0%9F%D0%B0%D0%BC%D1%8F%D1%82%D0%BD%D0%B8%D0%BA%D0%B8_%D0%B0%D1%80%D1%85%D1%96%D1%82%D0%B5%D0%BA%D1%82%D1%83%D1%80%D0%B8/%D0%BA%D0%BB%D1%83%D0%B1-%D0%BF%D1%80%D0%BE%D0%BC%D0%B8%D1%81%D0%BB%D0%BE%D0%B2%D0%BE%D1%97-%D0%BA%D0%BE%D0%BE%D0%BF%D0%B5%D1%80%D0%B0%D1%86%D1%96%D1%97-%D0%BE%D0%B1%D0%BB%D0%B0%D1%81%D0%BD%D0%B0/2612/?setcity=592", "attr_Title": "Клуб промислової кооперації (мур.)", "attr_Статус": "Щойно виявлений об'єкт", "attr_Охоронний номер": null, "attr_Вид": "Архітектура", "attr_Країна": "Україна", "attr_Область": "Хмельницька", "attr_Місто": "Хмельницький", "attr_Тип ВДМ": "вул.", "attr_Вулиця": "Героїв Маріуполя", "attr_Номер будинку": "7", "attr_для геокодування": "Україна Хмельницька Хмельницький вул.Героїв Маріуполя, 7", "attr_Latitude": "49.41835020000001", "attr_Longitude": 26.9766929, "attr_Дата рішення": "15.09.2010", "attr_Номер рішення": 242, "attr_Орган прийняття (оригінальна назва)": "Хмельницька міська Рада народних депутатів", "attr_Орган прийняття (тип)": "Міська рада", "attr_Власність": "Комунальна", "attr_Датування": "1960 р.", "attr_Дата початку": null, "attr_Дата завершення": null, "attr_Первісне призначення": "Клуб", "attr_Сучасне призначення": "Філармонія", "attr_Матеріал": "Цегла", "attr_Автор": null, "attr_Основні розміри": null }, "geometry": { "type": "Polygon", "coordinates": [ [ [ 26.9759975, 49.4188544 ], [ 26.9763817, 49.4188148 ], [ 26.9763731, 49.4187794 ], [ 26.9764972, 49.418